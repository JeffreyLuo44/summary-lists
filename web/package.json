{
  "name": "summary-lists-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --base /summary-lists/",
    "preview": "vite preview",
    "deploy": "npm run build:pages && npm exec -- gh-pages -d dist"
  },
  "dependencies": {
    "firebase": "^11.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "gh-pages": "^6.3.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}



